{
  "components": {
    "schemas": {
      "AuthLoginRequest": {
        "type": "object",
        "required": ["email", "contrasenia"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@correo.com"
          },
          "contrasenia": {
            "type": "string",
            "example": "admin123"
          }
        }
      },
      "AuthLoginSuccess": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        }
      },
      "ValidationErrors": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "example": "field" },
                "msg": {
                  "type": "string",
                  "example": "Revisar el formato del correo electr\u00f3nico."
                },
                "path": { "type": "string", "example": "email" },
                "location": { "type": "string", "example": "body" }
              }
            }
          }
        }
      },
      "AuthBadRequest": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": false },
          "mensaje": {
            "type": "string",
            "example": "Solicitud incorrecta."
          }
        }
      },
      "RecuperarPasswordRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "usuario@correo.com"
          }
        }
      },
      "RecuperarPasswordSuccess": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "mensaje": {
            "type": "string",
            "example": "Token de recuperación generado exitosamente"
          },
          "token": {
            "type": "string",
            "example": "abc123xyz456"
          },
          "nota": {
            "type": "string",
            "example": "En producción, este token se enviaría por email"
          }
        }
      },
      "ValidarTokenSuccess": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "mensaje": {
            "type": "string",
            "example": "Token válido"
          },
          "email": {
            "type": "string",
            "example": "usuario@correo.com"
          }
        }
      },
      "RestablecerPasswordRequest": {
        "type": "object",
        "required": ["contrasenia"],
        "properties": {
          "contrasenia": {
            "type": "string",
            "minLength": 6,
            "example": "nuevaContraseña123"
          }
        }
      },
      "RestablecerPasswordSuccess": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "mensaje": {
            "type": "string",
            "example": "Contraseña actualizada exitosamente"
          }
        }
      }
    }
  },
  "/api/v1/auth/login": {
    "post": {
      "summary": "Inicia sesi\u00f3n y devuelve un token JWT",
      "tags": ["Auth"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/AuthLoginRequest" },
            "examples": {
              "login": {
                "value": {
                  "email": "admin@correo.com",
                  "contrasenia": "admin123"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Login exitoso",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthLoginSuccess" }
            }
          }
        },
        "400": {
          "description": "Credenciales incorrectas o error de validaci\u00f3n",
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/AuthBadRequest" },
                  { "$ref": "#/components/schemas/ValidationErrors" }
                ]
              },
              "examples": {
                "credenciales": {
                  "value": {
                    "estado": false,
                    "mensaje": "Solicitud incorrecta."
                  }
                },
                "email-invalido": {
                  "value": {
                    "errors": [
                      {
                        "type": "field",
                        "msg": "Revisar el formato del correo electr\u00f3nico.",
                        "path": "email",
                        "location": "body"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/auth/recuperar": {
    "post": {
      "summary": "Solicita recuperación de contraseña",
      "tags": ["Auth"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/RecuperarPasswordRequest" },
            "examples": {
              "recuperar": {
                "value": {
                  "email": "usuario@correo.com"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Token de recuperación generado exitosamente",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecuperarPasswordSuccess" }
            }
          }
        },
        "400": {
          "description": "Email no encontrado o error de validación",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthBadRequest" }
            }
          }
        },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/auth/validar-token/{token}": {
    "get": {
      "summary": "Valida si un token de recuperación es válido",
      "tags": ["Auth"],
      "parameters": [
        {
          "name": "token",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "Token de recuperación a validar"
        }
      ],
      "responses": {
        "200": {
          "description": "Token válido",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ValidarTokenSuccess" }
            }
          }
        },
        "400": {
          "description": "Token inválido o expirado",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthBadRequest" }
            }
          }
        },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/auth/restablecer/{token}": {
    "post": {
      "summary": "Restablece la contraseña usando un token válido",
      "tags": ["Auth"],
      "parameters": [
        {
          "name": "token",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "Token de recuperación válido"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/RestablecerPasswordRequest" },
            "examples": {
              "restablecer": {
                "value": {
                  "contrasenia": "nuevaContraseña123"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Contraseña actualizada exitosamente",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RestablecerPasswordSuccess" }
            }
          }
        },
        "400": {
          "description": "Token inválido, expirado o error de validación",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthBadRequest" }
            }
          }
        },
        "500": { "description": "Error interno" }
      }
    }
  }
}
