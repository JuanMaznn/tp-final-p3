{
  "/api/v1/auth/login": {
    "post": {
      "summary": "Inicia sesión y devuelve un token JWT",
      "tags": ["Auth"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "email": { "type": "string" },
                "contrasenia": { "type": "string" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "description": "Login exitoso, devuelve token" }
      }
    }
  }
}
