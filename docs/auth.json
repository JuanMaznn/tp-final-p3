{
  "components": {
    "schemas": {
      "AuthLoginRequest": {
        "type": "object",
        "required": ["email", "contrasenia"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@correo.com"
          },
          "contrasenia": {
            "type": "string",
            "example": "admin123"
          }
        }
      },
      "AuthLoginSuccess": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        }
      },
      "ValidationErrors": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "example": "field" },
                "msg": {
                  "type": "string",
                  "example": "Revisar el formato del correo electr\u00f3nico."
                },
                "path": { "type": "string", "example": "email" },
                "location": { "type": "string", "example": "body" }
              }
            }
          }
        }
      },
      "AuthBadRequest": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": false },
          "mensaje": {
            "type": "string",
            "example": "Solicitud incorrecta."
          }
        }
      }
    }
  },
  "/api/v1/auth/login": {
    "post": {
      "summary": "Inicia sesi\u00f3n y devuelve un token JWT",
      "tags": ["Auth"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/AuthLoginRequest" },
            "examples": {
              "login": {
                "value": {
                  "email": "admin@correo.com",
                  "contrasenia": "admin123"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Login exitoso",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthLoginSuccess" }
            }
          }
        },
        "400": {
          "description": "Credenciales incorrectas o error de validaci\u00f3n",
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/AuthBadRequest" },
                  { "$ref": "#/components/schemas/ValidationErrors" }
                ]
              },
              "examples": {
                "credenciales": {
                  "value": {
                    "estado": false,
                    "mensaje": "Solicitud incorrecta."
                  }
                },
                "email-invalido": {
                  "value": {
                    "errors": [
                      {
                        "type": "field",
                        "msg": "Revisar el formato del correo electr\u00f3nico.",
                        "path": "email",
                        "location": "body"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "500": { "description": "Error interno" }
      }
    }
  }
}
