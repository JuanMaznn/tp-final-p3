{
  "components": {
    "schemas": {
      "Especialidad": {
        "type": "object",
        "properties": {
          "id_especialidad": { "type": "integer", "example": 1 },
          "nombre": { "type": "string", "example": "PEDIATRÍA" },
          "activo": { "type": "integer", "example": 1 }
        }
      },
      "EspecialidadRequest": {
        "type": "object",
        "required": ["nombre"],
        "properties": {
          "nombre": { "type": "string", "example": "CARDIOLOGÍA" }
        }
      },
      "EspecialidadResponse": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "msg": { "type": "string", "example": "ID Creado 16" }
        }
      },
      "EspecialidadMessage": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "msg": { "type": "string", "example": "Especialidad modificada" }
        }
      },
      "EspecialidadError": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": false },
          "msg": { "type": "string", "example": "Especialidad no encontrada" }
        }
      }
    }
  },
  "/api/v1/especialidades": {
    "get": {
      "summary": "Lista todas las especialidades activas",
      "tags": ["Especialidades"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "Lista de especialidades",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "especialidades": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Especialidad" }
                  }
                }
              }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado" }
      }
    },
    "post": {
      "summary": "Crea una nueva especialidad (Admin)",
      "tags": ["Especialidades"],
      "security": [{ "bearerAuth": [] }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/EspecialidadRequest" }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Especialidad creada",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EspecialidadResponse" }
            }
          }
        },
        "400": { "description": "Error de validacion: nombre obligatorio" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/especialidades/{id_especialidad}": {
    "get": {
      "summary": "Obtiene una especialidad por ID",
      "tags": ["Especialidades"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_especialidad",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "Especialidad encontrada",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "especialidad": { "$ref": "#/components/schemas/Especialidad" }
                }
              }
            }
          }
        },
        "400": { "description": "id_especialidad debe ser entero" },
        "404": { "description": "Especialidad no encontrada" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado" }
      }
    },
    "put": {
      "summary": "Actualiza una especialidad (Admin)",
      "tags": ["Especialidades"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_especialidad",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/EspecialidadRequest" }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Especialidad actualizada",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EspecialidadMessage" }
            }
          }
        },
        "400": { "description": "Error de validacion" },
        "404": { "description": "Especialidad no encontrada" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    },
    "delete": {
      "summary": "Elimina una especialidad (Admin)",
      "tags": ["Especialidades"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_especialidad",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "Especialidad eliminada",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EspecialidadMessage" }
            }
          }
        },
        "404": { "description": "Especialidad no encontrada" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  }
}
