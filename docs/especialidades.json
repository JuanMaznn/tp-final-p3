{
  "/api/v1/especialidades": {
    "get": {
      "summary": "Lista todas las especialidades activas",
      "tags": ["Especialidades"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": { "description": "Lista de especialidades" }
      }
    },
    "post": {
      "summary": "Crea una nueva especialidad (Admin)",
      "tags": ["Especialidades"],
      "security": [{ "bearerAuth": [] }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": { "nombre": { "type": "string" } }
            }
          }
        }
      },
      "responses": {
        "201": { "description": "Especialidad creada" }
      }
    }
  },
  "/api/v1/especialidades/{id}": {
    "get": {
      "summary": "Obtiene una especialidad por ID",
      "tags": ["Especialidades"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [{
        "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }
      }],
      "responses": {
        "200": { "description": "Especialidad encontrada" }
      }
    }
  }
}
