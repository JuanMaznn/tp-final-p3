{
  "components": {
    "schemas": {
      "ValidationErrors": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "example": "field" },
                "msg": {
                  "type": "string",
                  "example": "El par\u00e1metro debe ser entero"
                },
                "path": { "type": "string", "example": "id_usuario" },
                "location": { "type": "string", "example": "params" }
              }
            }
          }
        }
      },
      "UsuarioCreateRequest": {
        "type": "object",
        "required": [
          "documento",
          "apellido",
          "nombres",
          "email",
          "contrasenia",
          "rol"
        ],
        "properties": {
          "documento": {
            "type": "string",
            "example": "41000114"
          },
          "apellido": {
            "type": "string",
            "example": "Martinez"
          },
          "nombres": {
            "type": "string",
            "example": "Ana"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "ana@correo.com"
          },
          "contrasenia": {
            "type": "string",
            "example": "anamar123"
          },
          "rol": {
            "type": "integer",
            "description": "1=Medico, 2=Paciente, 3=Admin",
            "example": 2
          },
          "id_obra_social": {
            "type": "integer",
            "description": "Obligatorio si rol=2",
            "example": 1
          },
          "id_especialidad": {
            "type": "integer",
            "description": "Obligatorio si rol=1",
            "example": 2
          },
          "matricula": {
            "type": "integer",
            "description": "Obligatorio si rol=1",
            "example": 12345
          },
          "descripcion": {
            "type": "string",
            "description": "Opcional para medicos",
            "example": "Medico clinico"
          },
          "valor_consulta": {
            "type": "number",
            "description": "Obligatorio si rol=1",
            "example": 5000
          },
          "foto_path": {
            "type": "string",
            "example": "foto-1718380000000.jpg"
          }
        }
      },
      "UsuarioUpdateRequest": {
        "type": "object",
        "properties": {
          "documento": { "type": "string", "example": "41000114" },
          "apellido": { "type": "string", "example": "Martinez" },
          "nombres": { "type": "string", "example": "Ana Maria" },
          "email": {
            "type": "string",
            "format": "email",
            "example": "ana.maria@correo.com"
          },
          "contrasenia": { "type": "string", "example": "nuevaClave123" },
          "rol": {
            "type": "integer",
            "description": "1=Medico, 2=Paciente, 3=Admin",
            "example": 2
          },
          "id_obra_social": {
            "type": "integer",
            "description": "Requerido si rol=2",
            "example": 1
          },
          "id_especialidad": {
            "type": "integer",
            "description": "Requerido si rol=1",
            "example": 2
          },
          "matricula": {
            "type": "integer",
            "description": "Requerido si rol=1",
            "example": 12346
          },
          "descripcion": {
            "type": "string",
            "example": "Descripcion actualizada"
          },
          "valor_consulta": {
            "type": "number",
            "example": 6500
          }
        }
      },
      "UsuarioCreateSuccess": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "mensaje": { "type": "string", "example": "Usuario creado." },
          "datos": {
            "type": "object",
            "properties": {
              "id_usuario": { "type": "integer", "example": 17 }
            }
          }
        }
      },
      "UsuarioListResponse": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "usuarios": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id_usuario": { "type": "integer", "example": 1 },
                "documento": { "type": "string", "example": "41000114" },
                "apellido": { "type": "string", "example": "Martinez" },
                "nombres": { "type": "string", "example": "Ana" },
                "email": { "type": "string", "example": "ana@correo.com" },
                "rol": { "type": "integer", "example": 2 },
                "foto_path": { "type": "string", "example": "" },
                "activo": { "type": "integer", "example": 1 }
              }
            }
          }
        }
      },
      "UsuarioMessageResponse": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "mensaje": { "type": "string", "example": "Usuario modificado." }
        }
      },
      "UsuarioErrorResponse": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": false },
          "mensaje": {
            "type": "string",
            "example": "Usuario no encontrado."
          }
        }
      }
    }
  },
  "/api/v1/usuarios": {
    "get": {
      "summary": "[Admin] Lista todos los usuarios activos",
      "tags": ["Usuarios"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "Lista de usuarios",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UsuarioListResponse" }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    },
    "post": {
      "summary": "[Admin] Registra un nuevo usuario",
      "tags": ["Usuarios"],
      "security": [{ "bearerAuth": [] }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/UsuarioCreateRequest" },
            "examples": {
              "paciente": {
                "value": {
                  "documento": "41000114",
                  "apellido": "Martinez",
                  "nombres": "Ana",
                  "email": "ana@correo.com",
                  "contrasenia": "anamar123",
                  "rol": 2,
                  "id_obra_social": 1
                }
              },
              "medico": {
                "value": {
                  "documento": "31000115",
                  "apellido": "Garcia",
                  "nombres": "Carlos",
                  "email": "carlos@correo.com",
                  "contrasenia": "cargar123",
                  "rol": 1,
                  "id_especialidad": 2,
                  "matricula": 12345,
                  "descripcion": "Medico clinico",
                  "valor_consulta": 5000
                }
              }
            }
          },
          "multipart/form-data": {
            "schema": {
              "allOf": [
                { "$ref": "#/components/schemas/UsuarioCreateRequest" },
                {
                  "type": "object",
                  "properties": {
                    "foto": {
                      "type": "string",
                      "format": "binary",
                      "description": "Foto de perfil"
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Usuario creado",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UsuarioCreateSuccess" }
            }
          }
        },
        "400": {
          "description": "Error de validaci\u00f3n o email duplicado",
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/UsuarioErrorResponse" },
                  { "$ref": "#/components/schemas/ValidationErrors" }
                ]
              },
              "examples": {
                "duplicado": {
                  "value": {
                    "estado": false,
                    "mensaje": "El email ya est\u00e1 registrado"
                  }
                },
                "validacion": {
                  "value": {
                    "errors": [
                      {
                        "type": "field",
                        "msg": "Matr\u00edcula debe ser un entero positivo",
                        "path": "matricula",
                        "location": "body"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/usuarios/{id_usuario}": {
    "get": {
      "summary": "[Admin] Obtiene un usuario por ID",
      "tags": ["Usuarios"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_usuario",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "Usuario encontrado",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "usuario": {
                    "type": "object",
                    "properties": {
                      "id_usuario": { "type": "integer", "example": 1 },
                      "documento": { "type": "string", "example": "41000114" },
                      "apellido": { "type": "string", "example": "Martinez" },
                      "nombres": { "type": "string", "example": "Ana" },
                      "email": { "type": "string", "example": "ana@correo.com" },
                      "rol": { "type": "integer", "example": 2 },
                      "foto_path": { "type": "string", "example": "" },
                      "activo": { "type": "integer", "example": 1 }
                    }
                  }
                }
              }
            }
          }
        },
        "404": {
          "description": "Usuario no encontrado",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UsuarioErrorResponse" }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    },
    "put": {
      "summary": "[Admin] Modifica un usuario",
      "tags": ["Usuarios"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_usuario",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/UsuarioUpdateRequest" }
          },
          "multipart/form-data": {
            "schema": {
              "allOf": [
                { "$ref": "#/components/schemas/UsuarioUpdateRequest" },
                {
                  "type": "object",
                  "properties": {
                    "foto": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Usuario modificado",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UsuarioMessageResponse" }
            }
          }
        },
        "400": {
          "description": "Error de validaci\u00f3n",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ValidationErrors" },
              "examples": {
                "id": {
                  "value": {
                    "errors": [
                      {
                        "type": "field",
                        "msg": "El par\u00e1metro debe ser entero",
                        "path": "id_usuario",
                        "location": "params"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "404": {
          "description": "Usuario no encontrado",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UsuarioErrorResponse" }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    },
    "delete": {
      "summary": "[Admin] Desactiva un usuario",
      "tags": ["Usuarios"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_usuario",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "Usuario desactivado",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "mensaje": {
                    "type": "string",
                    "example": "Usuario desactivado."
                  }
                }
              }
            }
          }
        },
        "400": {
          "description": "ID inv\u00e1lido",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ValidationErrors" }
            }
          }
        },
        "404": {
          "description": "Usuario no encontrado",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UsuarioErrorResponse" }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  }
}
