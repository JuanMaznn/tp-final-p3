{
  "components": {
    "schemas": {
      "Turno": {
        "type": "object",
        "description": "Detalle completo con datos del medico y paciente (usado en GET /{id} y POST)",
        "properties": {
          "id_turno_reserva": { "type": "integer", "example": 1 },
          "id_medico": { "type": "integer", "example": 1 },
          "id_paciente": { "type": "integer", "example": 1 },
          "id_obra_social": { "type": "integer", "example": 1 },
          "fecha_hora": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-01T20:00:00.000Z"
          },
          "valor_total": { "type": "string", "example": "4500.00" },
          "atentido": { "type": "integer", "example": 0 },
          "activo": { "type": "integer", "example": 1 },
          "paciente_nombres": { "type": "string", "example": "Jacinto" },
          "paciente_apellido": { "type": "string", "example": "Lopez" },
          "paciente_documento": { "type": "string", "example": "41000111" },
          "medico_nombres": { "type": "string", "example": "Marcelo" },
          "medico_apellido": { "type": "string", "example": "Lopez" },
          "medico_documento": { "type": "string", "example": "31000111" }
        }
      },
      "TurnoListadoAdmin": {
        "type": "object",
        "description": "Admin: ve todos los turnos con datos del medico y del paciente",
        "properties": {
          "id_turno_reserva": { "type": "integer", "example": 1 },
          "fecha_hora": { "type": "string", "format": "date-time", "example": "2026-04-01T20:00:00.000Z" },
          "valor_total": { "type": "string", "example": "4500.00" },
          "atentido": { "type": "integer", "example": 0 },
          "paciente_nombres": { "type": "string", "example": "Jacinto" },
          "paciente_apellido": { "type": "string", "example": "Lopez" },
          "paciente_documento": { "type": "string", "example": "41000111" },
          "medico_nombres": { "type": "string", "example": "Marcelo" },
          "medico_apellido": { "type": "string", "example": "Lopez" },
          "medico_documento": { "type": "string", "example": "31000111" }
        }
      },
      "TurnoListadoMedico": {
        "type": "object",
        "description": "Medico: solo sus turnos con datos del paciente",
        "properties": {
          "id_turno_reserva": { "type": "integer", "example": 1 },
          "fecha_hora": { "type": "string", "format": "date-time", "example": "2026-04-01T20:00:00.000Z" },
          "valor_total": { "type": "string", "example": "4500.00" },
          "atentido": { "type": "integer", "example": 0 },
          "paciente_nombres": { "type": "string", "example": "Jacinto" },
          "paciente_apellido": { "type": "string", "example": "Lopez" },
          "paciente_documento": { "type": "string", "example": "41000111" },
          "obra_social": { "type": "string", "example": "jer" }
        }
      },
      "TurnoListadoPaciente": {
        "type": "object",
        "description": "Paciente: solo sus turnos con datos del medico",
        "properties": {
          "id_turno_reserva": { "type": "integer", "example": 1 },
          "fecha_hora": { "type": "string", "format": "date-time", "example": "2026-04-01T20:00:00.000Z" },
          "valor_total": { "type": "string", "example": "4500.00" },
          "atentido": { "type": "integer", "example": 0 },
          "medico_nombres": { "type": "string", "example": "Marcelo" },
          "medico_apellido": { "type": "string", "example": "Lopez" },
          "medico_documento": { "type": "string", "example": "31000111" }
        }
      },
      "TurnoCreacion": {
        "type": "object",
        "required": ["id_medico", "id_paciente", "fecha_hora"],
        "properties": {
          "id_medico": { "type": "integer", "example": 2 },
          "id_paciente": { "type": "integer", "example": 5 },
          "fecha_hora": {
            "type": "string",
            "description": "Formato esperado: YYYY-MM-DD HH:mm:ss",
            "example": "2026-06-15 10:00:00"
          }
        }
      },
      "TurnoActualizacion": {
        "type": "object",
        "required": ["id_medico", "id_paciente", "fecha_hora"],
        "properties": {
          "id_medico": { "type": "integer", "example": 2 },
          "id_paciente": { "type": "integer", "example": 5 },
          "fecha_hora": {
            "type": "string",
            "description": "Formato esperado: YYYY-MM-DD HH:mm:ss",
            "example": "2026-06-15 10:00:00"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": false },
          "mensaje": { "type": "string", "example": "El medico no existe." }
        }
      },
      "OkResponse": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "mensaje": {
            "type": "string",
            "example": "Turno creado correctamente."
          }
        }
      }
    }
  },
  "/api/v1/turnos": {
    "get": {
      "summary": "Lista turnos del usuario autenticado",
      "tags": ["Turnos"],
      "security": [{ "bearerAuth": [] }],
      "description": "Cada turno incluye documento del medico y/o paciente segun el ROL:\n- Admin: id_turno_reserva, fecha_hora, valor_total, atentido, paciente_nombres, paciente_apellido, paciente_documento, medico_nombres, medico_apellido, medico_documento\n- Medico: id_turno_reserva, fecha_hora, valor_total, atentido, paciente_nombres, paciente_apellido, paciente_documento, obra_social\n- Paciente: id_turno_reserva, fecha_hora, valor_total, atentido, medico_nombres, medico_apellido, medico_documento",
      "responses": {
        "200": {
          "description": "Turnos encontrados.",
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  { "$ref": "#/components/schemas/OkResponse" },
                  {
                    "type": "object",
                    "properties": {
                      "turnos": {
                        "type": "array",
                        "items": {
                          "$ref": "#/components/schemas/TurnoListadoAdmin"
                        }
                      }
                    }
                  }
                ]
              },
              "examples": {
                "ok-admin": {
                  "summary": "Admin: ve todos con datos de medico y paciente",
                  "value": {
                    "estado": true,
                    "mensaje": "Turnos encontrados.",
                    "turnos": [
                      {
                        "id_turno_reserva": 1,
                        "fecha_hora": "2026-04-01T20:00:00.000Z",
                        "valor_total": "4500.00",
                        "atentido": 0,
                        "paciente_nombres": "Jacinto",
                        "paciente_apellido": "Lopez",
                        "paciente_documento": "41000111",
                        "medico_nombres": "Marcelo",
                        "medico_apellido": "Lopez",
                        "medico_documento": "31000111"
                      }
                    ]
                  }
                },
                "ok-medico": {
                  "summary": "Medico: solo sus turnos con datos del paciente",
                  "value": {
                    "estado": true,
                    "mensaje": "Turnos encontrados.",
                    "turnos": [
                      {
                        "id_turno_reserva": 1,
                        "fecha_hora": "2026-04-01T20:00:00.000Z",
                        "valor_total": "4500.00",
                        "atentido": 0,
                        "paciente_nombres": "Jacinto",
                        "paciente_apellido": "Lopez",
                        "paciente_documento": "41000111",
                        "obra_social": "jer"
                      }
                    ]
                  }
                },
                "ok-paciente": {
                  "summary": "Paciente: solo sus turnos con datos del medico",
                  "value": {
                    "estado": true,
                    "mensaje": "Turnos encontrados.",
                    "turnos": [
                      {
                        "id_turno_reserva": 1,
                        "fecha_hora": "2026-04-01T20:00:00.000Z",
                        "valor_total": "4500.00",
                        "atentido": 0,
                        "medico_nombres": "Marcelo",
                        "medico_apellido": "Lopez",
                        "medico_documento": "31000111"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado" },
        "500": { "description": "Error interno" }
      }
    },
    "post": {
      "summary": "Crea una reserva de turno",
      "tags": ["Turnos"],
      "security": [{ "bearerAuth": [] }],
      "description": "La fecha_hora debe enviarse con formato YYYY-MM-DD HH:mm:ss. Ejemplo valido: 2026-06-15 10:00:00.",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/TurnoCreacion" },
            "examples": {
              "turno": {
                "value": {
                  "id_medico": 2,
                  "id_paciente": 5,
                  "fecha_hora": "2026-06-15 10:00:00"
                }
              }
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Turno creado correctamente.",
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  { "$ref": "#/components/schemas/OkResponse" },
                  {
                    "type": "object",
                    "properties": {
                      "turno": { "$ref": "#/components/schemas/Turno" }
                    }
                  }
                ]
              },
              "examples": {
                "creado": {
                  "value": {
                    "estado": true,
                    "mensaje": "Turno creado correctamente.",
                    "turno": {
                      "id_turno_reserva": 8,
                      "id_medico": 2,
                      "id_paciente": 5,
                      "id_obra_social": 3,
                      "fecha_hora": "2026-06-15T10:00:00.000Z",
                      "valor_total": "12000.00",
                      "atentido": 0,
                      "activo": 1,
                      "paciente_nombres": "Lorena",
                      "paciente_apellido": "Hunk",
                      "paciente_documento": "41000112",
                      "medico_nombres": "Horacio",
                      "medico_apellido": "Benitez",
                      "medico_documento": "31000113"
                    }
                  }
                }
              }
            }
          }
        },
        "400": {
          "description": "Faltan campos requeridos, el formato de fecha es invalido o el medico/paciente no existe.",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ErrorResponse" },
              "examples": {
                "medico": {
                  "value": {
                    "estado": false,
                    "mensaje": "El medico no existe."
                  }
                }
              }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo paciente o admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/turnos/{id_turno}": {
    "get": {
      "summary": "Obtiene un turno por ID",
      "tags": ["Turnos"],
      "security": [{ "bearerAuth": [] }],
      "description": "Admin: cualquier turno. Medico/Paciente: solo turnos propios.",
      "parameters": [
        {
          "name": "id_turno",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "Turno encontrado.",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "turno": { "$ref": "#/components/schemas/Turno" }
                }
              }
            }
          }
        },
        "400": { "description": "id_turno debe ser entero." },
        "404": { "description": "Turno no encontrado o no tienes acceso" },
        "401": { "description": "No autorizado" },
        "500": { "description": "Error interno" }
      }
    },
    "put": {
      "summary": "Modifica un turno (Admin)",
      "tags": ["Turnos"],
      "security": [{ "bearerAuth": [] }],
      "description": "La fecha_hora debe enviarse con formato YYYY-MM-DD HH:mm:ss. Ejemplo valido: 2026-06-15 10:00:00.",
      "parameters": [
        {
          "name": "id_turno",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/TurnoActualizacion" },
            "examples": {
              "turno": {
                "value": {
                  "id_medico": 2,
                  "id_paciente": 5,
                  "fecha_hora": "2026-06-15 10:00:00"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Turno modificado. Se recalcula valor_total automaticamente.",
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  { "$ref": "#/components/schemas/OkResponse" },
                  {
                    "type": "object",
                    "properties": {
                      "turno": { "$ref": "#/components/schemas/Turno" }
                    }
                  }
                ]
              },
              "examples": {
                "modificado": {
                  "value": {
                    "estado": true,
                    "mensaje": "Turno modificado.",
                    "turno": {
                      "id_medico": 2,
                      "id_paciente": 5,
                      "fecha_hora": "2026-06-15 10:00:00",
                      "valor_total": 12000
                    }
                  }
                }
              }
            }
          }
        },
        "400": {
          "description": "Datos invalidos, fecha_hora invalida o medico/paciente inexistente.",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ErrorResponse" },
              "examples": {
                "paciente": {
                  "value": {
                    "estado": false,
                    "mensaje": "El paciente no existe."
                  }
                }
              }
            }
          }
        },
        "404": { "description": "Turno no encontrado o datos invalidos" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/turnos/{id_turno}/atender": {
    "put": {
      "summary": "Marca un turno como atendido (Medico o Admin)",
      "tags": ["Turnos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_turno",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "Turno marcado como atendido.",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OkResponse" },
              "examples": {
                "ok": {
                  "value": {
                    "estado": true,
                    "mensaje": "Turno marcado como atendido"
                  }
                }
              }
            }
          }
        },
        "400": { "description": "id_turno debe ser entero." },
        "404": { "description": "Turno no encontrado o no te pertenece" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo medico o admin)" },
        "500": { "description": "Error interno" }
      }
    }
  }
}
