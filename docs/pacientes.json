{
  "components": {
    "schemas": {
      "PacienteCompleto": {
        "type": "object",
        "properties": {
          "id_paciente": { "type": "integer", "example": 1 },
          "id_usuario": { "type": "integer", "example": 5 },
          "apellido": { "type": "string", "example": "Lopez" },
          "nombres": { "type": "string", "example": "Jacinto" },
          "email": { "type": "string", "example": "lopjac@correo.com" },
          "id_obra_social": { "type": "integer", "example": 1 },
          "descripcion_obra_social": { "type": "string", "example": "jer" },
          "foto_path": { "type": "string", "example": "" }
        }
      },
      "PacienteResumen": {
        "type": "object",
        "properties": {
          "id_paciente": { "type": "integer", "example": 1 },
          "id_usuario": { "type": "integer", "example": 5 },
          "id_obra_social": { "type": "integer", "example": 1 }
        }
      },
      "PacienteObraSocialRequest": {
        "type": "object",
        "required": ["id_obra_social"],
        "properties": {
          "id_obra_social": { "type": "integer", "example": 2 }
        }
      },
      "PacienteMessage": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "mensaje": { "type": "string", "example": "Obra social asociada correctamente." }
        }
      },
      "PacienteError": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": false },
          "mensaje": { "type": "string", "example": "Paciente no encontrado" }
        }
      }
    }
  },
  "/api/v1/pacientes": {
    "get": {
      "summary": "Lista todos los pacientes",
      "tags": ["Pacientes"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "Lista de pacientes",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "mensaje": { "type": "string", "example": "Pacientes encontrados." },
                  "pacientes": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/PacienteCompleto" }
                  }
                }
              }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin y medicos)" }
      }
    }
  },
  "/api/v1/pacientes/{id_paciente}": {
    "get": {
      "summary": "Obtiene un paciente por ID",
      "tags": ["Pacientes"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_paciente",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "Paciente encontrado",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "paciente": { "$ref": "#/components/schemas/PacienteResumen" }
                }
              }
            }
          }
        },
        "400": { "description": "id_paciente debe ser entero" },
        "404": { "description": "Paciente no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado" }
      }
    }
  },
  "/api/v1/pacientes/{id_paciente}/obra-social": {
    "put": {
      "summary": "Asocia una obra social a un paciente (Admin)",
      "tags": ["Pacientes"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_paciente",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/PacienteObraSocialRequest" }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Obra social asociada correctamente",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PacienteMessage" }
            }
          }
        },
        "400": { "description": "Error de validacion u obra social inexistente" },
        "404": { "description": "Paciente no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  }
}
