{
  "components": {
    "schemas": {
      "MedicoResumen": {
        "type": "object",
        "properties": {
          "id_medico": { "type": "integer", "example": 1 },
          "id_usuario": { "type": "integer", "example": 3 },
          "apellido": { "type": "string", "example": "Perez" },
          "nombres": { "type": "string", "example": "Juan" },
          "email": { "type": "string", "example": "juan@correo.com" },
          "foto_path": { "type": "string", "example": "medico-1.jpg" }
        }
      },
      "MedicoDetalle": {
        "type": "object",
        "properties": {
          "id_medico": { "type": "integer", "example": 1 },
          "id_usuario": { "type": "integer", "example": 3 },
          "id_especialidad": { "type": "integer", "example": 2 },
          "matricula": { "type": "integer", "example": 12345 },
          "descripcion": { "type": "string", "example": "Medico clinico" },
          "valor_consulta": { "type": "string", "example": "5000.00" }
        }
      },
      "MedicoUpdateRequest": {
        "type": "object",
        "required": [
          "id_especialidad",
          "descripcion",
          "matricula",
          "valor_consulta"
        ],
        "properties": {
          "id_especialidad": { "type": "integer", "example": 2 },
          "descripcion": { "type": "string", "example": "Descripcion nueva" },
          "matricula": { "type": "integer", "example": 45678 },
          "valor_consulta": { "type": "number", "example": 9000 }
        }
      },
      "MedicoEspecialidadRequest": {
        "type": "object",
        "required": ["id_especialidad"],
        "properties": {
          "id_especialidad": { "type": "integer", "example": 2 }
        }
      },
      "MedicoObrasSocialesRequest": {
        "type": "object",
        "required": ["obras_sociales"],
        "properties": {
          "obras_sociales": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id_obra_social"],
              "properties": {
                "id_obra_social": { "type": "integer", "example": 1 }
              }
            }
          }
        }
      }
    }
  },
  "/api/v1/medicos": {
    "get": {
      "summary": "Lista todos los m\u00e9dicos",
      "tags": ["M\u00e9dicos"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "M\u00e9dicos encontrados",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "mensaje": {
                    "type": "string",
                    "example": "M\u00e9dicos encontrados."
                  },
                  "medicos": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/MedicoResumen" }
                  }
                }
              }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/medicos/{id_medico}": {
    "get": {
      "summary": "Busca un m\u00e9dico por ID",
      "tags": ["M\u00e9dicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_medico",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "M\u00e9dico encontrado",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "medico": { "$ref": "#/components/schemas/MedicoDetalle" }
                }
              }
            }
          }
        },
        "400": { "description": "El ID debe ser un n\u00famero entero" },
        "404": { "description": "M\u00e9dico no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado" },
        "500": { "description": "Error interno" }
      }
    },
    "put": {
      "summary": "Actualiza un m\u00e9dico",
      "tags": ["M\u00e9dicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_medico",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/MedicoUpdateRequest" }
          }
        }
      },
      "responses": {
        "200": {
          "description": "M\u00e9dico actualizado",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "msg": { "type": "string", "example": "Medico modificado" }
                }
              }
            }
          }
        },
        "400": { "description": "Error de validaci\u00f3n" },
        "404": { "description": "M\u00e9dico no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/medicos/especialidad/{id_especialidad}": {
    "get": {
      "summary": "Lista m\u00e9dicos por especialidad",
      "tags": ["M\u00e9dicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_especialidad",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "M\u00e9dicos filtrados por especialidad",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "medicos": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/MedicoResumen" }
                  }
                }
              }
            }
          }
        },
        "400": { "description": "Debe ser entero." },
        "404": { "description": "Especialidad no encontrada o inactiva" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/medicos/{id_medico}/especialidad": {
    "put": {
      "summary": "Asocia una especialidad a un m\u00e9dico",
      "tags": ["M\u00e9dicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_medico",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/MedicoEspecialidadRequest"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Especialidad asociada correctamente",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "mensaje": {
                    "type": "string",
                    "example": "Especialidad asociada correctamente"
                  }
                }
              }
            }
          }
        },
        "400": { "description": "id_especialidad inv\u00e1lido o faltante" },
        "404": { "description": "M\u00e9dico no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/medicos/{id_medico}/obras-sociales": {
    "put": {
      "summary": "Asocia obras sociales a un m\u00e9dico",
      "tags": ["M\u00e9dicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_medico",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/MedicoObrasSocialesRequest"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Obras sociales asociadas correctamente",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "mensaje": {
                    "type": "string",
                    "example": "Obras sociales asociadas correctamente"
                  }
                }
              }
            }
          }
        },
        "400": { "description": "Array inv\u00e1lido, vac\u00edo o con obra social inexistente" },
        "404": { "description": "M\u00e9dico no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  }
}
