{
  "/api/v1/medicos": {
    "get": {
      "summary": "Lista todos los médicos",
      "tags": ["Médicos"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "Lista de médicos",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "mensaje": { "type": "string", "example": "Médicos encontrados." },
                  "medicos": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id_medico": { "type": "integer" },
                        "id_usuario": { "type": "integer" },
                        "apellido": { "type": "string" },
                        "nombres": { "type": "string" },
                        "email": { "type": "string" },
                        "foto_path": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado"
        }
      }
    }
  },
  "/api/v1/medicos/{id_medico}": {
    "get": {
      "summary": "Busca un médico por ID",
      "tags": ["Médicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [{
        "name": "id_medico", "in": "path", "required": true, "schema": { "type": "integer" }
      }],
      "responses": {
        "200": {
          "description": "Médico encontrado",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "medico": {
                    "type": "object",
                    "properties": {
                      "id_medico": { "type": "integer" },
                      "id_usuario": { "type": "integer" },
                      "id_especialidad": { "type": "integer" },
                      "matricula": { "type": "integer" },
                      "descripcion": { "type": "string" },
                      "valor_consulta": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "404": { "description": "Médico no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado"
        }
      }
    },
    "put": {
      "summary": "Actualiza un médico (Admin)",
      "tags": ["Médicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [{
        "name": "id_medico", "in": "path", "required": true, "schema": { "type": "integer" }
      }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id_especialidad": { "type": "integer" },
                "matricula": { "type": "integer" },
                "descripcion": { "type": "string" },
                "valor_consulta": { "type": "number" }
              },
              "required": ["id_especialidad", "matricula", "descripcion", "valor_consulta"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Médico actualizado",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "msg": { "type": "string", "example": "Medico modificado" }
                }
              }
            }
          }
        },
        "400": { "description": "Error de validación: campos obligatorios / Especialidad no existe o está inactiva" },
        "404": { "description": "Médico no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/medicos/especialidad/{id_especialidad}": {
    "get": {
      "summary": "Lista médicos por especialidad",
      "tags": ["Médicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [{
        "name": "id_especialidad", "in": "path", "required": true, "schema": { "type": "integer" }
      }],
      "responses": {
        "200": {
          "description": "Médicos filtrados por especialidad",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "medicos": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id_medico": { "type": "integer" },
                        "apellido": { "type": "string" },
                        "nombres": { "type": "string" },
                        "email": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "404": { "description": "Especialidad no encontrada o inactiva" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado"
        }
      }
    }
  },
  "/api/v1/medicos/{id_medico}/especialidad": {
    "put": {
      "summary": "Asocia una especialidad a un médico (Admin)",
      "tags": ["Médicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [{
        "name": "id_medico", "in": "path", "required": true, "schema": { "type": "integer" }
      }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id_especialidad": { "type": "integer" }
              },
              "required": ["id_especialidad"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Especialidad asociada correctamente",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "mensaje": { "type": "string", "example": "Especialidad asociada correctamente" }
                }
              }
            }
          }
        },
        "400": { "description": "Especialidad no existe o está inactiva / id_especialidad requerido" },
        "404": { "description": "Médico no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/medicos/{id_medico}/obras-sociales": {
    "put": {
      "summary": "Asocia obras sociales a un médico (Admin)",
      "tags": ["Médicos"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [{
        "name": "id_medico", "in": "path", "required": true, "schema": { "type": "integer" }
      }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "obras_sociales": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id_obra_social": { "type": "integer" }
                    }
                  }
                }
              },
              "required": ["obras_sociales"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Obras sociales asociadas correctamente",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "mensaje": { "type": "string", "example": "Obras sociales asociadas correctamente" }
                }
              }
            }
          }
        },
        "400": { "description": "Obra social no existe o está inactiva / No se crearon las relaciones / obras_sociales requerido" },
        "404": { "description": "Médico no encontrado" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  }
}
