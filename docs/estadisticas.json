{
  "components": {
    "schemas": {
      "ResumenGeneral": {
        "type": "object",
        "properties": {
          "total_turnos": { "type": "integer", "example": 6 },
          "atendidos": { "type": "string", "example": "0" },
          "pendientes": { "type": "string", "example": "6" },
          "ingresos_totales": { "type": "string", "example": "178500.00" }
        }
      },
      "EstadisticaPorMedico": {
        "type": "object",
        "properties": {
          "apellido": { "type": "string", "example": "Lopez" },
          "nombres": { "type": "string", "example": "Marcelo" },
          "turnos": { "type": "integer", "example": 1 },
          "ingresos": { "type": "string", "example": "4500.00" }
        }
      },
      "EstadisticaPorEspecialidad": {
        "type": "object",
        "properties": {
          "especialidad": { "type": "string", "example": "CLÍNICA" },
          "turnos": { "type": "integer", "example": 1 },
          "ingresos": { "type": "string", "example": "4500.00" }
        }
      },
      "EstadisticaPorObraSocial": {
        "type": "object",
        "properties": {
          "obra_social": { "type": "string", "example": "Jerárquicos" },
          "turnos": { "type": "integer", "example": 1 },
          "ingresos": { "type": "string", "example": "4500.00" }
        }
      },
      "EstadisticasGenerales": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "mensaje": { "type": "string", "example": "Estadísticas obtenidas." },
          "resumen": { "$ref": "#/components/schemas/ResumenGeneral" },
          "porMedico": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EstadisticaPorMedico" }
          },
          "porEspecialidad": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EstadisticaPorEspecialidad" }
          },
          "porObraSocial": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EstadisticaPorObraSocial" }
          }
        }
      },
      "ResumenMedico": {
        "type": "object",
        "properties": {
          "total_turnos": { "type": "integer", "example": 5 },
          "atendidos": { "type": "string", "example": "2" },
          "pendientes": { "type": "string", "example": "3" },
          "ingresos_totales": { "type": "string", "example": "45000.00" }
        }
      },
      "EstadisticaPorPaciente": {
        "type": "object",
        "properties": {
          "apellido": { "type": "string", "example": "Aguirre" },
          "nombres": { "type": "string", "example": "Brian" },
          "total_turnos": { "type": "integer", "example": 1 },
          "atendidos": { "type": "string", "example": "1" },
          "pendientes": { "type": "string", "example": "0" },
          "ingresos": { "type": "string", "example": "4450.00" }
        }
      },
      "EstadisticasMedico": {
        "type": "object",
        "properties": {
          "estado": { "type": "boolean", "example": true },
          "mensaje": { "type": "string", "example": "Estadísticas del médico." },
          "resumen": { "$ref": "#/components/schemas/ResumenMedico" },
          "porPaciente": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EstadisticaPorPaciente" }
          }
        }
      }
    }
  },
  "/api/v1/estadisticas": {
    "get": {
      "summary": "Obtiene estadisticas generales (Admin)",
      "tags": ["Estadisticas"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "Estadisticas obtenidas",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EstadisticasGenerales" }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/estadisticas/medico": {
    "get": {
      "summary": "Obtiene estadisticas del medico autenticado",
      "tags": ["Estadisticas"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "Estadisticas del medico",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EstadisticasMedico" }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo medico)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/estadisticas/pdf": {
    "get": {
      "summary": "Descarga PDF de estadisticas (Admin)",
      "tags": ["Estadisticas"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "PDF generado",
          "content": {
            "application/pdf": {
              "schema": { "type": "string", "format": "binary" }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error al generar PDF" }
      }
    }
  },
  "/api/v1/estadisticas/medico/pdf": {
    "get": {
      "summary": "Descarga PDF de estadisticas del medico",
      "tags": ["Estadisticas"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "PDF generado",
          "content": {
            "application/pdf": {
              "schema": { "type": "string", "format": "binary" }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo medico)" },
        "500": { "description": "Error al generar PDF" }
      }
    }
  }
}
