{
  "/api/v1/obras-sociales": {
    "get": {
      "summary": "Lista todas las obras sociales activas",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "Obras sociales encontradas",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "obrasSociales": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id_obra_social": { "type": "integer" },
                        "nombre": { "type": "string" },
                        "descripcion": { "type": "string" },
                        "porcentaje_descuento": { "type": "string" },
                        "es_particular": { "type": "integer" },
                        "activo": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado"
        }
      }
    },
    "post": {
      "summary": "Crea una obra social (Admin)",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "nombre": { "type": "string" },
                "descripcion": { "type": "string" },
                "porcentajeDescuento": { "type": "number" },
                "esParticular": { "type": "boolean" }
              },
              "required": ["nombre", "descripcion", "porcentajeDescuento", "esParticular"]
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Obra social creada",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "msg": { "type": "string", "example": "Obra Social creada. ID 17" }
                }
              }
            }
          }
        },
        "400": { "description": "Error de validación: nombre, descripcion, porcentajeDescuento y esParticular obligatorios" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/obras-sociales/{id_obra_social}": {
    "get": {
      "summary": "Obtiene una obra social por ID",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [{
        "name": "id_obra_social", "in": "path", "required": true, "schema": { "type": "integer" }
      }],
      "responses": {
        "200": {
          "description": "Obra social encontrada",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "obraSocial": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id_obra_social": { "type": "integer" },
                        "nombre": { "type": "string" },
                        "descripcion": { "type": "string" },
                        "porcentaje_descuento": { "type": "string" },
                        "es_particular": { "type": "integer" },
                        "activo": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "404": { "description": "Obra Social no encontrada" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado"
        }
      }
    },
    "put": {
      "summary": "Actualiza una obra social (Admin)",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [{
        "name": "id_obra_social", "in": "path", "required": true, "schema": { "type": "integer" }
      }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "nombre": { "type": "string" },
                "descripcion": { "type": "string" },
                "porcentajeDescuento": { "type": "number" },
                "esParticular": { "type": "boolean" }
              },
              "required": ["nombre", "descripcion", "porcentajeDescuento", "esParticular"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Obra social actualizada",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "msg": { "type": "string", "example": "Obra Social modificada" }
                }
              }
            }
          }
        },
        "400": { "description": "Error de validación" },
        "404": { "description": "Obra Social no encontrada" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    },
    "delete": {
      "summary": "Elimina (desactiva) una obra social (Admin)",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [{
        "name": "id_obra_social", "in": "path", "required": true, "schema": { "type": "integer" }
      }],
      "responses": {
        "200": {
          "description": "Obra social desactivada",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "msg": { "type": "string", "example": "Obra Social eliminada." }
                }
              }
            }
          }
        },
        "404": { "description": "Obra Social no encontrada" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  }
}
