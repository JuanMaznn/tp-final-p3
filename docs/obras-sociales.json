{
  "components": {
    "schemas": {
      "ObraSocial": {
        "type": "object",
        "properties": {
          "id_obra_social": { "type": "integer", "example": 1 },
          "nombre": { "type": "string", "example": "OSDE" },
          "descripcion": { "type": "string", "example": "Plan 210" },
          "porcentaje_descuento": { "type": "string", "example": "20.00" },
          "es_particular": { "type": "integer", "example": 0 },
          "activo": { "type": "integer", "example": 1 }
        }
      },
      "ObraSocialRequest": {
        "type": "object",
        "required": [
          "nombre",
          "descripcion",
          "porcentajeDescuento",
          "esParticular"
        ],
        "properties": {
          "nombre": { "type": "string", "example": "OSDE" },
          "descripcion": { "type": "string", "example": "Plan 210" },
          "porcentajeDescuento": { "type": "number", "example": 20 },
          "esParticular": { "type": "boolean", "example": false }
        }
      }
    }
  },
  "/api/v1/obras-sociales": {
    "get": {
      "summary": "Lista todas las obras sociales activas",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "responses": {
        "200": {
          "description": "Obras sociales encontradas",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "obrasSociales": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/ObraSocial" }
                  }
                }
              }
            }
          }
        },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado" },
        "500": { "description": "Error interno" }
      }
    },
    "post": {
      "summary": "Crea una obra social",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ObraSocialRequest" },
            "examples": {
              "obra-social": {
                "value": {
                  "nombre": "OSDE",
                  "descripcion": "Plan 210",
                  "porcentajeDescuento": 20,
                  "esParticular": false
                }
              }
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Obra social creada",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "msg": {
                    "type": "string",
                    "example": "Obra Social creada. ID 17"
                  }
                }
              }
            }
          }
        },
        "400": { "description": "Error de validaci\u00f3n" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  },
  "/api/v1/obras-sociales/{id_obra_social}": {
    "get": {
      "summary": "Obtiene una obra social por ID",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_obra_social",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "Obra social encontrada",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "obraSocial": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/ObraSocial" }
                  }
                }
              }
            }
          }
        },
        "400": { "description": "El ID debe ser un n\u00famero entero" },
        "404": { "description": "Obra Social no encontrada" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado" },
        "500": { "description": "Error interno" }
      }
    },
    "put": {
      "summary": "Actualiza una obra social",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_obra_social",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ObraSocialRequest" }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Obra social actualizada",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "msg": {
                    "type": "string",
                    "example": "Obra Social modificada"
                  }
                }
              }
            }
          }
        },
        "400": { "description": "ID inv\u00e1lido o error de validaci\u00f3n" },
        "404": { "description": "Obra Social no encontrada" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    },
    "delete": {
      "summary": "Desactiva una obra social",
      "tags": ["Obras Sociales"],
      "security": [{ "bearerAuth": [] }],
      "parameters": [
        {
          "name": "id_obra_social",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": {
          "description": "Obra social desactivada",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": { "type": "boolean", "example": true },
                  "msg": {
                    "type": "string",
                    "example": "Obra Social eliminada."
                  }
                }
              }
            }
          }
        },
        "400": { "description": "El ID debe ser un n\u00famero entero" },
        "404": { "description": "Obra Social no encontrada" },
        "401": { "description": "No autorizado" },
        "403": { "description": "Acceso denegado (solo admin)" },
        "500": { "description": "Error interno" }
      }
    }
  }
}
